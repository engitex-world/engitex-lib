{
  "name": "engitex-lib",
  "version": "1.0.0",
  "description": "Engitex Lib",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src --dts --format esm,cjs --outDir dist",
    "checkup": "yarn lint && yarn format",
    "format": "prettier --write .",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "keywords": [],
  "author": "Engitex",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@types/node": "22.19.17",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "7.18.0"
  }
}
