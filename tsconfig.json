{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@constants": ["constants"],
      "@enums": ["enums"],
      "@mappings": ["mappings"],
      "@translations": ["translations"],
      "@types": ["types"],
      "@utils": ["utils"],
    }
  },
  "include": ["src"]
}
