{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@lib/constants": ["constants"],
      "@lib/enums": ["enums"],
      "@lib/mappings": ["mappings"],
      "@lib/translations": ["translations"],
      "@lib/types": ["types"],
      "@lib/utils": ["utils"],
    }
  },
  "include": ["src"]
}
