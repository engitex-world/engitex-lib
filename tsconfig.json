{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "paths": {
      "@lib/common/*": ["./src/common/*"],
      "@lib/modules/*": ["./src/modules/*"],
      "@lib/translations": ["./src/translations"]
    }
  },
  "include": ["src"]
}
