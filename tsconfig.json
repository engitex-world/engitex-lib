{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "paths": {
      "@lib/common/*": ["common/*"],
      "@lib/modules/*": ["modules/*"],
      "@lib/translations": ["translations"]
    }
  },
  "include": ["src"]
}
