{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "declaration": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@constants/*": ["./src/constants/*"],
      "@enums/*": ["./src/enums/*"],
      "@mappings/*": ["./src/mappings/*"],
      "@translations/*": ["./src/translations/*"],
      "@types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
